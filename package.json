{
  "name": "stackrun",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma full-stack open-source com suporte nativo a Dart/Vaden",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:dashboard\" \"pnpm run dev:control-plane\"",
    "dev:dashboard": "pnpm --filter @stackrun/dashboard dev",
    "dev:control-plane": "pnpm --filter @stackrun/control-plane dev",
    "build": "pnpm --filter @stackrun/control-plane build && pnpm --filter @stackrun/dashboard build",
    "db:generate": "pnpm --filter @stackrun/control-plane db:generate",
    "db:push": "pnpm --filter @stackrun/control-plane db:push",
    "db:studio": "pnpm --filter @stackrun/control-plane db:studio",
    "db:seed": "pnpm --filter @stackrun/control-plane db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
