{
  "dashboard": {
    "title": "StackRun Overview",
    "uid": "stackrun-overview",
    "panels": [
      {"title":"Deploys/hour","type":"graph","targets":[{"expr":"rate(stackrun_deploy_total[1h])"}]},
      {"title":"API req/s","type":"graph","targets":[{"expr":"rate(stackrun_api_requests_total[5m])"}]},
      {"title":"Proxy cache hit %","type":"stat","targets":[{"expr":"stackrun_proxy_cache_hits/(stackrun_proxy_cache_hits+stackrun_proxy_cache_misses)*100"}]},
      {"title":"Active projects","type":"stat","targets":[{"expr":"count(stackrun_project_status{status=\"ACTIVE\"})"}]},
      {"title":"Rust proxy RAM","type":"gauge","targets":[{"expr":"stackrun_proxy_memory_bytes/1024/1024"}]},
      {"title":"Edge req/s","type":"graph","targets":[{"expr":"rate(stackrun_edge_requests_total[5m])"}]},
      {"title":"Edge cold start p99","type":"stat","targets":[{"expr":"histogram_quantile(0.99,rate(stackrun_edge_cold_start_seconds_bucket[5m]))*1000"}]},
      {"title":"Build duration","type":"graph","targets":[{"expr":"histogram_quantile(0.50,rate(stackrun_build_duration_seconds_bucket[5m]))","legendFormat":"p50"},{"expr":"histogram_quantile(0.95,rate(stackrun_build_duration_seconds_bucket[5m]))","legendFormat":"p95"},{"expr":"histogram_quantile(0.99,rate(stackrun_build_duration_seconds_bucket[5m]))","legendFormat":"p99"}]},
      {"title":"Health check","type":"stat","targets":[{"expr":"avg(stackrun_health_check_status)"}]}
    ]
  }
}
