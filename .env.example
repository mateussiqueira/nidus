# Nidus — Local Environment

# Dashboard (Next.js)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3000

# Control Plane (NestJS)
API_PORT=3001
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development
NIDUS_HOST=localhost

# Database
DATABASE_URL=postgresql://broto:broto@localhost:5432/nidus?schema=public

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD:-nidus-redis-pass}@localhost:6379
REDIS_PASSWORD=nidus-redis-pass

# JWT
JWT_SECRET=local_nidus_jwt_secret_change_me

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
