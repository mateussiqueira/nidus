# Canopy — Ambiente Local

# Dashboard (Next.js)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3000

# Control Plane (NestJS)
API_PORT=3001
CORS_ORIGINS=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://canopy:canopy@localhost:5433/canopy?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=canopy
MINIO_ROOT_PASSWORD=canopy-canopy
MINIO_BUCKET=canopy-storage

# Auth (GoTrue)
GOTRUE_URL=http://localhost:9999
GOTRUE_JWT_SECRET=local_canopy_jwt_secret_change_me
GOTRUE_ADMIN_EMAIL=admin@canopy.local
GOTRUE_ADMIN_PASSWORD=admin123

# Router (Caddy)
CADDY_ADMIN_API=http://localhost:2019
CANOPY_ROOT_DOMAIN=canopy.localhost

# JWT
JWT_SECRET=local_canopy_jwt_secret_change_me

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
