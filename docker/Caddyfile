{
  admin :2019
}

# Custom domain support - replace nidus.example.com with your domain
# For production, use: https://{$NIDUS_ROOT_DOMAIN}
nidus.localhost, *.nidus.localhost {
  tls internal

  handle_path /api/* {
    reverse_proxy host.docker.internal:3001
  }

  handle_path /auth/* {
    reverse_proxy host.docker.internal:9999
  }

  handle {
    reverse_proxy host.docker.internal:3000
  }
}

# Wildcard domain for custom deployments
# Uncomment and configure for production:
# {$NIDUS_ROOT_DOMAIN} {
#   tls {
#     protocols tls1.2 tls1.3
#   }
