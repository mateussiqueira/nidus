{
  "title": "Nidus Platform",
  "tags": [
    "nidus"
  ],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "API Requests",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(nidus_requests_total[5m])",
          "legendFormat": "requests/s"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "title": "Containers CPU",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"$container.*\"}[5m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 1,
      "title": "Containers Memory",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{name=~\"$container.*\"}) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1
        }
      },
      "datasource": "Prometheus"
    },
    {
      "title": "System Memory",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk %"
        }
      ],
      "datasource": "Prometheus"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "query": "label_values(container_cpu_usage_seconds_total{name=~\".+\"}, name)",
        "datasource": "Prometheus",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  }
}